{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-empty-pattern": [
      "error",
      {
        "allowObjectPatternsAsParameters": true
      }
    ]
  },
  "env": {
    "builtin": true
  }
}
